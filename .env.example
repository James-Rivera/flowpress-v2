# Local filesystem root for customer uploads.
# Example on the host PC: C:\flowpress-local\uploads
UPLOADS_DIR=uploads

# Optional upload limits
UPLOAD_MAX_FILE_COUNT=20
UPLOAD_MAX_FILE_SIZE_MB=100
UPLOAD_MAX_BATCH_SIZE_MB=500
NEXT_PUBLIC_UPLOAD_MAX_FILE_COUNT=20
NEXT_PUBLIC_UPLOAD_MAX_FILE_SIZE_MB=100
NEXT_PUBLIC_UPLOAD_MAX_BATCH_SIZE_MB=500

# Optional external contact links shown on the send hub.
NEXT_PUBLIC_MESSENGER_WEB_URL=https://m.me/cjnetvalley
NEXT_PUBLIC_MESSENGER_APP_URL=fb-messenger://user-thread/cjnetvalley
NEXT_PUBLIC_GMAIL_TO=cjnetvalley@gmail.com
NEXT_PUBLIC_GMAIL_SUBJECT=CJ NET Print Request
